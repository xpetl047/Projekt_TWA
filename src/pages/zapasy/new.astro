---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import AuthGuard from '../../components/AuthGuard.astro';
import { getHraci } from '../../lib/db';
const hraci = (await getHraci()).filter(h=>h.aktivni);
---
<MainLayout title="Přidat zápas | HC Mládež" activeNav="zapasy">
  <AuthGuard />
  <nav class="breadcrumb"><a href="/zapasy">← Zpět na zápasy</a></nav>
  <div class="card" x-data="newZapas()" x-init="init()" style="max-width:90rem">
    <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem">Přidat zápas</h2>
    <p class="alert alert-error"   x-show="error"   x-text="error" style="margin-bottom:1.6rem"></p>
    <p class="alert alert-success" x-show="success" style="margin-bottom:1.6rem">✅ Zápas uložen!</p>
    <div class="form-grid form-grid-2">
      <div class="form-group"><label>Datum *</label><input class="input" type="date" x-model="f.datum" /></div>
      <div class="form-group"><label>Kategorie *</label><select class="input" x-model="f.kategorie" @change="loadHraci()"><option>U8-U10</option><option>U11-U12</option><option selected>U13-U14</option><option>U15-U16</option><option>U17-U20</option></select></div>
      <div class="form-group"><label>Soupeř *</label><input class="input" type="text" x-model="f.souper" placeholder="HC Pardubice U14" /></div>
      <div class="form-group"><label>Místo</label><select class="input" x-model="f.domaci"><option :value="true">Domácí</option><option :value="false">Hosté</option></select></div>
      <div class="form-group"><label>Naše skóre</label><input class="input" type="number" x-model="f.skore_my" min="0" /></div>
      <div class="form-group"><label>Skóre soupeře</label><input class="input" type="number" x-model="f.skore_souper" min="0" /></div>
      <div class="form-group col-full"><label>Poznámka</label><input class="input" type="text" x-model="f.poznamka" /></div>
    </div>
    <div style="font-size:1.2rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#6b7280;border-bottom:.1rem solid #e4e4e4;padding-bottom:.8rem;margin:2rem 0 1.4rem">Statistiky hráčů</div>
    <table class="table" style="margin-bottom:1.6rem">
      <thead><tr><th>Hráč</th><th style="width:7rem">G</th><th style="width:7rem">A</th><th style="width:7rem">+/−</th><th style="width:7rem">TM</th></tr></thead>
      <tbody>
        <template x-for="s in stats" :key="s.hrac_id">
          <tr>
            <td x-text="s.jmeno"></td>
            <td><input class="input" type="number" min="0" x-model="s.goly"      style="padding:.4rem;text-align:center" /></td>
            <td><input class="input" type="number" min="0" x-model="s.asistence" style="padding:.4rem;text-align:center" /></td>
            <td><input class="input" type="number"         x-model="s.plusMinus" style="padding:.4rem;text-align:center" /></td>
            <td><input class="input" type="number" min="0" x-model="s.trestne"   style="padding:.4rem;text-align:center" /></td>
          </tr>
        </template>
        <tr x-show="stats.length===0"><td colspan="5" class="empty-state">Vyberte kategorii výše.</td></tr>
      </tbody>
    </table>
    <div class="form-actions">
      <a href="/zapasy" class="btn btn-secondary">Zrušit</a>
      <button class="btn btn-primary" :disabled="saving" @click="save()">
        <span x-show="!saving">Přidat zápas</span><span x-show="saving">Ukládám...</span>
      </button>
    </div>
  </div>
  <script define:vars={{ hraci }}>
    function newZapas() {
      const tr=()=>{try{return JSON.parse(localStorage.getItem('trener_session')||'null');}catch{return null;}};
      return {
        f:{datum:new Date().toISOString().slice(0,10),kategorie:'U13-U14',souper:'',domaci:true,skore_my:0,skore_souper:0,poznamka:''},
        stats:[],saving:false,success:false,error:'',
        init(){this.loadHraci();},
        loadHraci(){this.stats=hraci.filter(h=>h.kategorie===this.f.kategorie).map(h=>({hrac_id:h.id,jmeno:h.prijmeni+' '+h.jmeno,goly:0,asistence:0,plusMinus:0,trestne:0}));},
        async save(){
          if(!this.f.souper||!this.f.datum){this.error='Vyplňte soupeře a datum.';return;}
          this.saving=true;this.error='';
          const payload={...this.f,trener:tr()?.jmeno||'',stats:this.stats.filter(s=>s.goly||s.asistence||s.plusMinus||s.trestne).map(s=>({id:'',zapas_id:'',hrac_id:s.hrac_id,goly:+s.goly,asistence:+s.asistence,plusMinus:+s.plusMinus,trestne:+s.trestne}))};
          try{const res=await fetch('/api/zapasy',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});if(!res.ok)throw new Error('Chyba');this.success=true;setTimeout(()=>window.location.href='/zapasy',1000);}
          catch(e){this.error=e.message;}finally{this.saving=false;}
        }
      };
    }
  </script>
</MainLayout>
