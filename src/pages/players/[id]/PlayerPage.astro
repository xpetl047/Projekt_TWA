---
export const prerender = false;

import AuthGuard from '../../../components/AuthGuard.astro';
import '../../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';

const { id } = Astro.params;
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Detail hráče</title>
  </head>
  <body>
    <AuthGuard />

    <div class="container" style="max-width: 80rem; margin-top: 4rem; margin-bottom: 4rem;">
      
      <h1 style="margin-bottom: 2.4rem;">Detail hráče</h1>

      <div class="card" x-data="playerDetail()" x-init={`loadPlayer('${id}')`}>
        
        <div x-show="loading" style="text-align: center; padding: 2.4rem 0; color: #6b7280;">
          Načítání hráče...
        </div>

        <div x-show="error" class="alert alert-error">
          <p x-text="error" style="margin: 0; font-weight: 500;"></p>
          <a href="/players" style="display: inline-block; margin-top: 0.8rem; color: inherit; text-decoration: underline;">
            ← Zpět na seznam
          </a>
        </div>

        <div x-show="!loading && !error && player">
          
          <div class="row" style="margin-bottom: 1.6rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.8rem;">
            <div class="col-4">
              <strong style="color: #6b7280; font-size: 1.4rem;">Jméno</strong>
            </div>
            <div class="col-8">
              <span x-text="player.name" style="font-weight: 600; font-size: 1.6rem;"></span>
            </div>
          </div>

          <div class="row" style="margin-bottom: 1.6rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.8rem;">
            <div class="col-4">
              <strong style="color: #6b7280; font-size: 1.4rem;">Popis</strong>
            </div>
            <div class="col-8">
              <span x-text="player.description || 'Bez popisu'"></span>
            </div>
          </div>

          <div class="row" style="margin-bottom: 1.6rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.8rem;">
            <div class="col-4">
              <strong style="color: #6b7280; font-size: 1.4rem;">Status</strong>
            </div>
            <div class="col-8">
              <span 
                class="badge" 
                :class="{
                  'badge-open': player.status === 'active',
                  'badge-closed': player.status === 'inactive'
                }"
                x-text="player.status"
              ></span>
            </div>
          </div>

          <div class="row" style="margin-bottom: 1.6rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.8rem;">
            <div class="col-4">
              <strong style="color: #6b7280; font-size: 1.4rem;">Role</strong>
            </div>
            <div class="col-8">
              <span x-text="player.role" style="font-weight: 600;"></span>
            </div>
          </div>

          <div class="row" style="margin-bottom: 1.6rem;">
            <div class="col-4">
              <strong style="color: #6b7280; font-size: 1.4rem;">