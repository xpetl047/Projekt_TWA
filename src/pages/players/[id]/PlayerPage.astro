---
export const prerender = false;

import AuthGuard from '../../../components/AuthGuard.astro';
import '../../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';

const { id } = Astro.params;
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Detail hráče</title>
  </head>
  <body>
    <AuthGuard />

    <div class="container" style="max-width: 80rem; margin-top: 4rem; margin-bottom: 4rem;">
      
      <h1 style="margin-bottom: 2.4rem;">Detail hráče</h1>

      <div class="card" x-data="playerDetail()" x-init={`loadPlayer('${id}')`}>
        
        <div x-show="loading" style="text-align: center; padding: 2.4rem 0; color: #6b7280;">
          Načítání hráče...
        </div>

        <div x-show="error" class="alert alert-error">
          <p x-text="error" style="margin: 0; font-weight: 500;"></p>
          <a href="/players" style="display: inline-block; margin-top: 0.8rem; color: inherit; text-decoration: underline;">
            ← Zpět na seznam
          </a>
        </div>

        <template x-if="!loading && !error && player">
          <div>
            
            <div class="row" style="margin-bottom: 1.6rem; border-bottom: 0.1rem solid var(--table-border-color); padding-bottom: 0.8rem;">
              <div class="col-4">
                <strong style="color: var(--table-th-color); font-size: 1.4rem;">Jméno</strong>
              </div>
              <div class="col-8">
                <span x-text="player.name" style="font-weight: 600; font-size: 1.6rem;"></span>
              </div>
            </div>

            <div class="row" style="margin-bottom: 1.6rem; border-bottom: 0.1rem solid var(--table-border-color); padding-bottom: 0.8rem;">
              <div class="col-4">
                <strong style="color: var(--table-th-color); font-size: 1.4rem;">Popis</strong>
              </div>
              <div class="col-8">
                <span x-text="player.description || 'Bez popisu'"></span>
              </div>
            </div>

            <div class="row" style="margin-bottom: 1.6rem; border-bottom: 0.1rem solid var(--table-border-color); padding-bottom: 0.8rem;">
              <div class="col-4">
                <strong style="color: var(--table-th-color); font-size: 1.4rem;">Status</strong>
              </div>
              <div class="col-8">
                <span class="badge" :class="{'badge-open': player.status === 'active', 'badge-closed': player.status === 'inactive'}" x-text="player.status"></span>
              </div>
            </div>

            <div class="row" style="margin-bottom: 1.6rem; border-bottom: 0.1rem solid var(--table-border-color); padding-bottom: 0.8rem;">
              <div class="col-4">
                <strong style="color: var(--table-th-color); font-size: 1.4rem;">Role</strong>
              </div>
              <div class="col-8">
                <span x-text="player.role" style="font-weight: 600;"></span>
              </div>
            </div>

            <div class="row" style="margin-bottom: 1.6rem;">
              <div class="col-4">
                <strong style="color: var(--table-th-color); font-size: 1.4rem;">Přiřazeno</strong>
              </div>
              <div class="col-8">
                <span x-text="player.assignee || 'Nepřiřazeno'"></span>
              </div>
            </div>

            <div style="display: flex; gap: 1.6rem; margin-top: 3.2rem;">
              <a href="/players" class="btn" style="background: #e5e7eb; color: #374151;">← Zpět na seznam</a>
              <a :href="`/players/${player.id}/edit`" class="btn btn-primary">Upravit hráče</a>
            </div>

          </div>
        </template>
      </div>
    </div>

    <script is:inline define:vars={{ playerId: id }}>
      window.playerDetail = function() {
        return {
          player: null,
          loading: true,
          error: null,

          async loadPlayer(id) {
            try {
              this.loading = true;
              this.error = null;
              
              const response = await fetch(`/api/players/${id}`);
              
              if (!response.ok) {
                if (response.status === 404) {
                  throw new Error('Hráč nenalezen');
                }
                throw new Error('Nepodařilo se načíst hráče');
              }
  
              this.player = await response.json();
            } catch (err) {
              this.error = err.message;
              console.error('Chyba při načítání:', err);
            } finally {
              this.loading = false;
            }
          }
        };
      };
    </script>
  </body>
</html>