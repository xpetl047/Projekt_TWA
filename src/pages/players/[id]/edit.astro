---
export const prerender = false;
import MainLayout from '../../../layouts/MainLayout.astro';
import AuthGuard from '../../../components/AuthGuard.astro';
import { getHrac } from '../../../lib/db';
const { id } = Astro.params;
const hrac = await getHrac(id!);
if (!hrac) return Astro.redirect('/players');
---
<MainLayout title={`Upravit ${hrac.jmeno} ${hrac.prijmeni}`} activeNav="players">
  <AuthGuard />
  <nav class="breadcrumb"><a href={`/players/${hrac.id}`}>← Zpět na profil</a></nav>

  <div class="card" x-data={`editHrac(${JSON.stringify(hrac)})`} style="max-width:80rem">
    <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem">Upravit hráče</h2>
    <p class="alert alert-error"   x-show="error"   x-text="error" style="margin-bottom:1.6rem"></p>
    <p class="alert alert-success" x-show="success" style="margin-bottom:1.6rem">✅ Uloženo!</p>

    <div class="form-section">Základní informace</div>
    <div class="form-grid">
      <div class="form-group">
        <label>Křestní jméno *</label>
        <input class="input" type="text" x-model="f.jmeno" />
      </div>
      <div class="form-group">
        <label>Příjmení *</label>
        <input class="input" type="text" x-model="f.prijmeni" />
      </div>
      <div class="form-group">
        <label>Číslo dresu</label>
        <input class="input" type="number" x-model="f.cislo" min="1" max="99" />
      </div>
      <div class="form-group">
        <label>Kategorie</label>
        <select class="input" x-model="f.kategorie">
          <option>U8-U10</option><option>U11-U12</option><option>U13-U14</option>
          <option>U15-U16</option><option>U17-U20</option>
        </select>
      </div>
      <div class="form-group">
        <label>Pozice</label>
        <select class="input" x-model="f.pozice">
          <option>Útočník</option><option>Obránce</option><option>Brankář</option>
        </select>
      </div>
      <div class="form-group">
        <label>Datum narození</label>
        <input class="input" type="date" x-model="f.narozeni" />
      </div>
      <div class="form-group">
        <label>Hokejka</label>
        <select class="input" x-model="f.ruka">
          <option>Levá</option><option>Pravá</option>
        </select>
      </div>
      <div class="form-group col-full">
        <label>Kontakt na rodiče</label>
        <input class="input" type="text" x-model="f.rodic_kontakt" />
      </div>
    </div>

    <div class="form-actions">
      <a href={`/players/${hrac.id}`} class="btn btn-secondary">Zrušit</a>
      <button class="btn btn-primary" :disabled="saving" @click="save()">
        <span x-show="!saving">Uložit změny</span>
        <span x-show="saving">Ukládám...</span>
      </button>
    </div>
  </div>

  <script>
    function editHrac(initial) {
      return {
        f: {...initial}, saving:false, success:false, error:'',
        async save() {
          this.saving=true; this.error=''; this.success=false;
          try {
            const res=await fetch(`/api/hraci/${initial.id}`,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(this.f)});
            if(!res.ok)throw new Error('Chyba');
            this.success=true;
            setTimeout(()=>window.location.href=`/players/${initial.id}`,1000);
          }catch(e){this.error=e.message;}
          finally{this.saving=false;}
        }
      };
    }
  </script>
</MainLayout>
