---
export const prerender = false;

import AuthGuard from '../../../components/AuthGuard.astro';
import '../../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';


const { id } = Astro.params;

---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Upravit hráče</title>
  </head>
  <body>
    <AuthGuard />

    <div class="container" style="padding-top: 4rem; padding-bottom: 4rem; max-width: 64rem;">
      <h1 style="font-size: 2.4rem; margin-bottom: 2.4rem;">Upravit hráče</h1>

            <div class="card" x-data="playerEdit()" x-init={`loadPlayer('${id}')`}>
        <!-- Loading state -->
        <div x-show="loading" style="padding: 2.4rem; text-align: center; color: #9ca3af;">
          Načítání hráče...
        </div>

        <!-- Error state -->
        <div x-show="error" style="padding: 2.4rem; text-align: center; color: #b91c1c;">
          <p x-text="error"></p>
          <a href="/players" style="margin-top: 1.2rem; display: inline-block;">← Zpět na seznam</a>
        </div>

        <!-- Edit form -->
 
        <form
           x-show="!loading && !error && player"
          @submit.prevent="savePlayer"
        >
          <div class="form-group">
            <label for="name">Jméno</label>
            <input class="input" type="text" id="name" name="name" x-model="player.name" required />
          </div>

          <div class="form-group">
            <label for="description">Popis</label>
            <textarea class="input" id="description" name="description" rows="4" style="resize: vertical;" x-model="player.description"></textarea>
          </div>

          <div class="form-group">
            <label for="status">Status</label>
            <select class="input" id="status" name="status" x-model="player.status">
              <option value="active" selected={player.status === 'active'}>active</option>
              <option value="inactive" selected={player.status === 'inactive'}>inactive</option>             
            </select>
          </div>

          <div class="form-group">
            <label for="role">Role</label>
            <select class="input" id="role" name="role">
              <option value="C"    selected={player.role === 'C'}>C</option>
              <option value="LW" selected={player.role === 'LW'}>LW</option>
              <option value="RW" selected={player.role === 'RW'}>RW</option>
              <option value="D" selected={player.role === 'D'}>D</option>
              <option value="G" selected={player.role === 'G'}>G</option>
            </select>
          </div>

          <div class="form-group">
            <label for="assignee">Přiřazeno</label>
            <input class="input" type="text" id="assignee" name="assignee" x-model="player.assignee" />
          </div>

          <div style="display: flex; gap: 1.2rem; margin-top: 2.4rem;">
             <button type="submit" class="btn btn-primary" :disabled="saving">
              <span x-show="!saving">Uložit</span>
              <span x-show="saving">Ukládání...</span>
            </button>
            <a href="/players" class="btn" style="background: #e5e7eb; color: #374151;">Zrušit</a>
          </div>
        </form>
      </div>
    </div>
     <script is:inline define:vars={{ playerId: id }}>
      window.playerEdit = function() {
        return {
          player: null,
          loading: true,
          saving: false,
          error: null,

          async loadPlayer(id) {
            try {
              this.loading = true;
              this.error = null;
              const response = await fetch(`/api/players/${id}`);
              
              if (!response.ok) {
                if (response.status === 404) {
                  throw new Error('Hráč nenalezen');
                }
                throw new Error('Nepodařilo se načíst hráče');
              }
              
              this.player = await response.json();
            } catch (err) {
              this.error = err.message;
            } finally {
              this.loading = false;
            }
          },

          async savePlayer(event) {
            if (this.saving) return;

            try {
              this.saving = true;
              const formData = new FormData(event.target);
              
              const response = await fetch(`/api/players/${playerId}`, {
                method: 'PUT',
                body: formData
              });

              if (!response.ok) {
                throw new Error('Nepodařilo se uložit hráče');
              }

              await response.json(); // parsuj odpověď
              window.location.href = '/players';
            } catch (err) {
              alert('Chyba při ukládání: ' + err.message);
            } finally {
              this.saving = false;
            }
          }
        };
      };
    </script>
  </body>
</html>
