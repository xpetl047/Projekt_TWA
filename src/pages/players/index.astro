---
import AuthGuard from '../../components/AuthGuard.astro';
import '../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';





import MainLayout from '../../layouts/MainLayout.astro';
import playersData from '../../data/players.json';
---
<MainLayout title="Soupiska hráčů">
  <div class="row">
    <div class="col-12">
      <h1>Soupiska hráčů</h1>
      <div class="card">
        <table class="table">
          <thead>
            <tr>
              <th>Hráč</th>
              <th>Kategorie</th>
              <th>Pozice</th>
              <th>Číslo</th>
              <th>Góly</th>
              <th>Akce</th>
            </tr>
          </thead>
          <tbody>
            {playersData.map((player) => (
              <tr>
                <td><strong>{player.name}<!-- {player.jmeno}--></strong></td>
               <!-- <td><span class="badge badge-open">{player.kat}</span></td>-->
                <!--<td><span class="badge badge-in-progress">{player.poz}</span></td>-->
                <!--<td>#{player.cislo}</td>-->
               <!-- <td>{player.goly}</td>-->
                <td>
                  <a href={`/players/${player.id}`} class="btn btn-primary">Detail</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script is:inline>
      window.playerList = function() {
        return {
          players: [],
          loading: true,
          error: null,

          init() {
            // Načti hráče při prvním zobrazení
            this.loadPlayers();
            
            // Refresh dat když se uživatel vrátí na stránku (např. z editace)
            window.addEventListener('pageshow', (event) => {
              // Pokud stránka přichází z cache (back/forward button), refresh
              if (event.persisted) {
                this.loadPlayers();
              }
            });
            
            // Refresh dat když získá stránka focus
            window.addEventListener('focus', () => {
              this.loadPlayers();
            });
            
            // Refresh dat když se stránka stane viditelná (např. po přepnutí tabu)
            document.addEventListener('visibilitychange', () => {
              if (!document.hidden) {
                this.loadPlayers();
              }
            });
          },

          async loadPlayers() {
            try {
              this.loading = true;
              this.error = null;
              const response = await fetch('/api/players?_=' + Date.now(), { 
                cache: 'no-store',
                headers: {
                  'Cache-Control': 'no-cache, no-store, must-revalidate',
                  'Pragma': 'no-cache'
                }
              });
              
              if (!response.ok) {
                throw new Error('Nepodařilo se načíst hráče');
              }
              
              this.players = await response.json();
            } catch (err) {
              this.error = err.message;
            } finally {
              this.loading = false;
            }
          },

          async deletePlayer(id) {
            if (!confirm('Opravdu smazat tohoto hráče?')) {
              return;
            }

            try {
              const response = await fetch(`/api/players/${id}`, {
                method: 'DELETE'
              });

              if (!response.ok) {
                throw new Error('Nepodařilo se smazat hráče ');
              }

              await this.loadPlayers();
            } catch (err) {
              alert('Chyba při mazání: ' + err.message);
            }
          }
        };
      };
    </script>
</MainLayout>

