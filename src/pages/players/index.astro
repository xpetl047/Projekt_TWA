---
import MainLayout from '../../layouts/MainLayout.astro';
import AuthGuard from '../../components/AuthGuard.astro';
---
<MainLayout title="Hráči | HC Mládež" activeNav="players">
  <AuthGuard />

  <div x-data="playersList()" x-init="init()">
    <div class="page-header">
      <div>
        <h1 class="page-title">Soupiska hráčů</h1>
        <p class="page-sub" x-text="`${filtered.length} hráčů`"></p>
      </div>
      <div class="page-actions">
        <a href="/players/new" class="btn btn-primary">+ Přidat hráče</a>
      </div>
    </div>

    <!-- Filtry -->
    <div class="card filters-bar">
      <div class="filter-group">
        <label>Hledat</label>
        <input class="input" type="text" placeholder="Jméno..." x-model="search" />
      </div>
      <div class="filter-group">
        <label>Kategorie</label>
        <select class="input" x-model="filterKat">
          <option value="">Všechny</option>
          <option>U8-U10</option><option>U11-U12</option><option>U13-U14</option>
          <option>U15-U16</option><option>U17-U20</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Pozice</label>
        <select class="input" x-model="filterPoz">
          <option value="">Všechny</option>
          <option>Útočník</option><option>Obránce</option><option>Brankář</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Řadit</label>
        <select class="input" x-model="sortBy">
          <option value="prijmeni">Příjmení</option>
          <option value="kategorie">Kategorie</option>
          <option value="cislo">Číslo dresu</option>
          <option value="narozeni">Věk</option>
        </select>
      </div>
    </div>

    <div x-show="loading" class="loading-state">
      <div class="spinner"></div><p>Načítám hráče...</p>
    </div>

    <div x-show="!loading" class="card" style="padding:0">
      <table class="table">
        <thead>
          <tr>
            <th>Hráč</th><th>Kategorie</th><th>Pozice</th>
            <th>Č.</th><th>Věk</th><th>G</th><th>A</th>
            <th>Testy</th><th>Hod.</th><th></th>
          </tr>
        </thead>
        <tbody>
          <template x-for="h in filtered" :key="h.id">
            <tr @click="window.location.href=`/players/${h.id}`">
              <td>
                <div class="name-cell">
                  <div class="avatar avatar-sm" :style="`background:${color(h.id)}`"
                    x-text="h.jmeno[0] + h.prijmeni[0]"></div>
                  <div>
                    <div class="player-name" x-text="h.prijmeni + ' ' + h.jmeno"></div>
                    <div class="player-quick" x-text="quickParams(h)"></div>
                  </div>
                </div>
              </td>
              <td><span class="badge badge-kat" x-text="h.kategorie"></span></td>
              <td>
                <span class="badge"
                  :class="h.pozice==='Útočník' ? 'badge-utocnik' : h.pozice==='Obránce' ? 'badge-obrance' : 'badge-brankar'"
                  x-text="h.pozice"></span>
              </td>
              <td class="font-bold" x-text="h.cislo"></td>
              <td x-text="vek(h.narozeni)"></td>
              <td class="font-bold text-success" x-text="golyH(h.id)"></td>
              <td x-text="asistH(h.id)"></td>
              <td>
                <span class="badge" :class="testyH(h.id) > 0 ? 'badge-closed' : 'badge-low'" x-text="testyH(h.id)"></span>
              </td>
              <td style="color:#f59e0b" x-text="hodH(h.id) ? '★'.repeat(hodH(h.id)) : '—'"></td>
              <td @click.stop>
                <div class="row-actions">
                  <a :href="`/players/${h.id}`"      class="btn btn-secondary btn-xs">Detail</a>
                  <a :href="`/players/${h.id}/edit`" class="btn btn-secondary btn-xs">Upravit</a>
                </div>
              </td>
            </tr>
          </template>
          <tr x-show="filtered.length === 0 && !loading">
            <td colspan="10" class="empty-state">Žádní hráči nenalezeni.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p x-show="!loading" class="text-sm text-muted" style="margin-top:.8rem"
      x-text="`Zobrazeno ${filtered.length} z ${hraci.length} hráčů`"></p>
  </div>

  <script is:inline>
    const KAT = ['U8-U10','U11-U12','U13-U14','U15-U16','U17-U20'];
    const COLORS = ['#1a56db','#7c3aed','#dc2626','#16a34a','#d97706','#0891b2','#db2777','#065f46','#1e40af','#9d174d','#92400e','#1e3a5f','#4338ca'];
    function playersList() {
      return {
        hraci:[], zapasy:[], testy:[], hodnoceniList:[],
        mereniMap: {}, dochPctMap: {},
        loading: true,
        search: new URLSearchParams(location.search).get('kategorie') ? '' : '',
        filterKat: new URLSearchParams(location.search).get('kategorie') ?? '',
        filterPoz: '', sortBy: 'prijmeni',
        async init() {
          const [h,z,t,ho,m,d] = await Promise.all([
            fetch('/api/hraci').then(r=>r.json()),
            fetch('/api/zapasy').then(r=>r.json()),
            fetch('/api/testy').then(r=>r.json()),
            fetch('/api/hodnoceni').then(r=>r.json()),
            fetch('/api/mereni').then(r=>r.json()),
            fetch('/api/dochazka').then(r=>r.json()),
          ]);

          const mereniMap = {};
          for (const rec of m) {
            const prev = mereniMap[rec.hrac_id];
            if (!prev || rec.datum > prev.datum) mereniMap[rec.hrac_id] = rec;
          }

          const totals = {};
          const present = {};
          for (const akce of d) {
            for (const z of (akce.zaznam || [])) {
              totals[z.hrac_id] = (totals[z.hrac_id] || 0) + 1;
              if (z.stav === 'pritomen') present[z.hrac_id] = (present[z.hrac_id] || 0) + 1;
            }
          }

          const dochPctMap = {};
          for (const hracId of Object.keys(totals)) {
            dochPctMap[hracId] = Math.round(((present[hracId] || 0) / totals[hracId]) * 100);
          }

          this.hraci=h; this.zapasy=z; this.testy=t; this.hodnoceniList=ho;
          this.mereniMap = mereniMap;
          this.dochPctMap = dochPctMap;
          this.loading=false;
        },
        get filtered() {
          let list = this.hraci.filter(h => h.aktivni);
          if (this.search) {
            const q = this.search.toLowerCase();
            list = list.filter(h => (h.jmeno+' '+h.prijmeni).toLowerCase().includes(q));
          }
          if (this.filterKat) list = list.filter(h => h.kategorie === this.filterKat);
          if (this.filterPoz) list = list.filter(h => h.pozice   === this.filterPoz);
          return [...list].sort((a,b) => {
            if (this.sortBy==='kategorie') return KAT.indexOf(a.kategorie)-KAT.indexOf(b.kategorie);
            if (this.sortBy==='cislo')     return a.cislo - b.cislo;
            if (this.sortBy==='narozeni')  return a.narozeni.localeCompare(b.narozeni);
            return a.prijmeni.localeCompare(b.prijmeni);
          });
        },
        color(id)   { const i=this.hraci.findIndex(h=>h.id===id); return COLORS[i%COLORS.length]; },
        golyH(id)   { return this.zapasy.flatMap(z=>z.stats).filter(s=>s.hrac_id===id).reduce((a,s)=>a+s.goly,0); },
        asistH(id)  { return this.zapasy.flatMap(z=>z.stats).filter(s=>s.hrac_id===id).reduce((a,s)=>a+s.asistence,0); },
        testyH(id)  { return this.testy.filter(t=>t.hrac_id===id).length; },
        hodH(id)    { const ho=this.hodnoceniList.filter(h=>h.hrac_id===id); return ho.length ? Math.round(ho[ho.length-1].celkove) : 0; },
        quickParams(h) {
          const m = this.mereniMap[h.id];
          const vyskaVal = m?.vyska_cm ?? h.vyska_cm;
          const vahaVal = m?.vaha_kg ?? h.vaha_kg;
          const vyska = vyskaVal != null ? `${vyskaVal} cm` : '— cm';
          const vaha = vahaVal != null ? `${vahaVal} kg` : '— kg';
          const doch = this.dochPctMap[h.id];
          const dochText = doch === undefined ? '— % docházka' : `${doch} % docházka`;
          return `${vyska} · ${vaha} · ${dochText}`;
        },
        vek(d)      { return new Date().getFullYear()-new Date(d).getFullYear(); },
      };
    }
  </script>
</MainLayout>
