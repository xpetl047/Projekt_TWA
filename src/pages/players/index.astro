---
import AuthGuard from '../../components/AuthGuard.astro';
import '../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';


---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hráči</title>
  </head>
  <body>
    <AuthGuard />

    <div class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.4rem;">
        <h1 style="font-size: 2.4rem; margin: 0;">Hráči</h1>  
        <a href="/players/new" class="btn btn-primary">+ Nový hráč</a>
      </div>

      <div class="card" x-data="playerList()" x-init="init()">
        <!-- Loading state -->
        <div x-show="loading" style="padding: 2.4rem; text-align: center; color: #9ca3af;">
          Načítání hráčů...
        </div>

        <!-- Error state -->
        <div x-show="error" style="padding: 2.4rem; text-align: center; color: #b91c1c;">
          <p x-text="error"></p>
        </div>

        <!-- Players table -->
        <table class="table" x-show="!loading && !error">
          </thead>
          <tbody>
            <template x-for="player in players" :key="player.id">
              <tr>
                <td style="color: #9ca3af;" x-text="player.id"></td>
                <td x-text="player.name"></td>
                <td>
                  <span :class="`badge badge-${player.status}`" x-text="player.status"></span>
                </td>
                <td>
                  <span :class="`badge badge-${player.role}`" x-text="player.role"></span>
                </td>
                <td x-text="player.assignee"></td>
                <td style="white-space: nowrap;">
                   <a :href="`/players/${player.id}/edit`" style="margin-right: 1.2rem;">Upravit</a>
                   <a :href="`/players/${player.id}/PlayerPage`" style="margin-right: 1.2rem;">PlayerPage</a>
                   <button
                    class="btn"
                    style="background: #fee2e2; color: #b91c1c; padding: 0.4rem 1rem; font-size: 1.3rem;"
                    x-data
                    @click="deletePlayer(player.id)"
                  >
                    Smazat
                  </button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
         <!-- Empty state -->
        <div x-show="!loading && !error && players.length === 0" style="padding: 2.4rem; text-align: center; color: #9ca3af;">
          Žádné hráče. <a :href="`/players/new`">Vytvořte první hráče</a>.
        </div>
      </div>

      <p style="margin-top: 2rem;"><a href="/">← Zpět</a></p>
    </div>
    <script is:inline>
      window.playerList = function() {
        return {
          players: [],
          loading: true,
          error: null,

          init() {
            // Načti hráče při prvním zobrazení
            this.loadPlayers();
            
            // Refresh dat když se uživatel vrátí na stránku (např. z editace)
            window.addEventListener('pageshow', (event) => {
              // Pokud stránka přichází z cache (back/forward button), refresh
              if (event.persisted) {
                this.loadPlayers();
              }
            });
            
            // Refresh dat když získá stránka focus
            window.addEventListener('focus', () => {
              this.loadPlayers();
            });
            
            // Refresh dat když se stránka stane viditelná (např. po přepnutí tabu)
            document.addEventListener('visibilitychange', () => {
              if (!document.hidden) {
                this.loadPlayers();
              }
            });
          },

          async loadPlayers() {
            try {
              this.loading = true;
              this.error = null;
              const response = await fetch('/api/players?_=' + Date.now(), { 
                cache: 'no-store',
                headers: {
                  'Cache-Control': 'no-cache, no-store, must-revalidate',
                  'Pragma': 'no-cache'
                }
              });
              
              if (!response.ok) {
                throw new Error('Nepodařilo se načíst hráče');
              }
              
              this.players = await response.json();
            } catch (err) {
              this.error = err.message;
            } finally {
              this.loading = false;
            }
          },

          async deletePlayer(id) {
            if (!confirm('Opravdu smazat tohoto hráče?')) {
              return;
            }

            try {
              const response = await fetch(`/api/players/${id}`, {
                method: 'DELETE'
              });

              if (!response.ok) {
                throw new Error('Nepodařilo se smazat hráče ');
              }

              await this.loadPlayers();
            } catch (err) {
              alert('Chyba při mazání: ' + err.message);
            }
          }
        };
      };
    </script>
  </body>
</html>
