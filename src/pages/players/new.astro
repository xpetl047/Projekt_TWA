---
import MainLayout from '../../layouts/MainLayout.astro';
import AuthGuard from '../../components/AuthGuard.astro';
---
<MainLayout title="Přidat hráče | HC Mládež" activeNav="players">
  <AuthGuard />
  <nav class="breadcrumb"><a href="/players">← Zpět na soupisku</a></nav>

  <div class="card" x-data="newHrac()" style="max-width:80rem">
    <h2 style="font-size:2rem;font-weight:700;margin-bottom:2rem">Přidat nového hráče</h2>
    <p class="alert alert-error" x-show="error" x-text="error" style="margin-bottom:1.6rem"></p>
    <p class="alert alert-success" x-show="success" style="margin-bottom:1.6rem">✅ Hráč přidán! Přesměrovávám...</p>

    <div class="form-section">Základní informace</div>
    <div class="form-grid">
      <div class="form-group col-full">
        <label>Křestní jméno *</label>
        <input class="input" type="text" x-model="f.jmeno" placeholder="Tomáš" />
      </div>
      <div class="form-group">
        <label>Příjmení *</label>
        <input class="input" type="text" x-model="f.prijmeni" placeholder="Novák" />
      </div>
      <div class="form-group">
        <label>Číslo dresu *</label>
        <input class="input" type="number" x-model="f.cislo" min="1" max="99" />
      </div>
      <div class="form-group">
        <label>Kategorie</label>
        <select class="input" x-model="f.kategorie">
          <option>U8-U10</option><option>U11-U12</option>
          <option selected>U13-U14</option><option>U15-U16</option><option>U17-U20</option>
        </select>
      </div>
      <div class="form-group">
        <label>Pozice</label>
        <select class="input" x-model="f.pozice">
          <option>Útočník</option><option>Obránce</option><option>Brankář</option>
        </select>
      </div>
      <div class="form-group">
        <label>Datum narození</label>
        <input class="input" type="date" x-model="f.narozeni" />
      </div>
      <div class="form-group">
        <label>Hokejka</label>
        <select class="input" x-model="f.ruka">
          <option>Levá</option><option>Pravá</option>
        </select>
      </div>
      <div class="form-group col-full">
        <label>Kontakt na rodiče</label>
        <input class="input" type="text" x-model="f.rodic_kontakt" placeholder="Jana Nováková, 777 123 456" />
      </div>
    </div>

    <div class="form-actions">
      <a href="/players" class="btn btn-secondary">Zrušit</a>
      <button class="btn btn-primary" :disabled="saving" @click="save()">
        <span x-show="!saving">Přidat hráče</span>
        <span x-show="saving">Ukládám...</span>
      </button>
    </div>
  </div>

  <script is:inline>
    function newHrac() {
      return {
        f: { jmeno:'', prijmeni:'', cislo:'', kategorie:'U13-U14',
             pozice:'Útočník', narozeni:'', ruka:'Levá', rodic_kontakt:'', aktivni:true },
        saving:false, success:false, error:'',
        async save() {
          if (!this.f.jmeno||!this.f.prijmeni||!this.f.cislo){this.error='Vyplňte jméno, příjmení a číslo.';return;}
          this.saving=true; this.error='';
          try {
            const res = await fetch('/api/hraci',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(this.f)});
            if (!res.ok) throw new Error('Chyba');
            const hrac = await res.json();
            this.success=true;
            setTimeout(()=>window.location.href=`/players/${hrac.id}`,1000);
          } catch(e) { this.error=e.message; }
          finally { this.saving=false; }
        }
      };
    }
  </script>
</MainLayout>
