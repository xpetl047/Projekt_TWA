---
import '../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';



import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Dashboard | HC Mládež">
  <div class="row">
    <div class="col-12">
      <h1>Dobrý den, Petře 👋</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-4">
      <div class="card">
        <h2>13</h2>
        <label>Hráčů celkem</label>
      </div>
    </div>
    <div class="col-4">
      <div class="card">
        <h2 class="badge-in-progress">5</h2>
        <label>Aktivních kategorií</label>
      </div>
    </div>
    <div class="col-4">
      <div class="card">
        <h2>3</h2>
        <label>Zápasů sezóny</label>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="card">
        <h3>Rychlé akce</h3>
        <div class="row">
          <div class="col-3">
            <a href="/players" class="btn btn-primary">Zobrazit hráče</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
			// Auth guard – nepřihlášený uživatel je přesměrován na /login
			if (!localStorage.getItem('auth')) {
				window.location.href = '/login';
			}

			document.getElementById('logout')?.addEventListener('click', () => {
				localStorage.removeItem('auth');
				window.location.href = '/login';
			});
		</script>
</MainLayout>
		

