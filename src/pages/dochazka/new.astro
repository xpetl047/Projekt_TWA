---
export const prerender = false;
import MainLayout from '../../layouts/MainLayout.astro';
import AuthGuard from '../../components/AuthGuard.astro';
import { getHraci } from '../../lib/db';
const hraci = (await getHraci()).filter(h=>h.aktivni);
---
<MainLayout title="Zapsat docházku | HC Mládež" activeNav="dochazka">
  <AuthGuard />
  <nav class="breadcrumb"><a href="/dochazka">← Zpět na docházku</a></nav>
  <div class="card" x-data="newDochazka()" x-init="init()" class="card-lg">
    <h2 class="form-title">Zapsat docházku</h2>
    <p class="alert alert-error" x-show="error" x-text="error"></p>
    <p class="alert alert-success" x-show="success">✅ Docházka uložena!</p>
    <div class="form-grid form-grid-3">
      <div class="form-group"><label>Datum *</label><input class="input" type="date" x-model="f.datum" /></div>
      <div class="form-group"><label>Typ akce</label><select class="input" x-model="f.typ"><option value="trenink">Trénink</option><option value="zapas">Zápas</option><option value="ostatni">Ostatní</option></select></div>
      <div class="form-group"><label>Popis</label><input class="input" type="text" x-model="f.popis" placeholder="Bruslení + střelba" /></div>
      <div class="form-group"><label>Kategorie</label><select class="input" x-model="f.kategorie" @change="loadHraci()"><option>U8-U10</option><option>U11-U12</option><option selected>U13-U14</option><option>U15-U16</option><option>U17-U20</option></select></div>
    </div>
    <div class="form-section">
      Hráči — <span x-text="f.kategorie"></span>
    </div>
    <table class="table">
      <thead><tr><th>Hráč</th><th style="text-align:center;width:8rem">Přítomen</th><th style="text-align:center;width:8rem">Omluven</th><th style="text-align:center;width:8rem">Neomluven</th><th>Poznámka</th></tr></thead>
      <tbody>
        <template x-for="z in zaznam" :key="z.hrac_id">
          <tr>
            <td x-text="z.jmeno"></td>
            <td class="td-center"><input type="radio" :name="`d_${z.hrac_id}`" value="pritomen" x-model="z.stav" /></td>
            <td class="td-center"><input type="radio" :name="`d_${z.hrac_id}`" value="omluven"  x-model="z.stav" /></td>
            <td class="td-center"><input type="radio" :name="`d_${z.hrac_id}`" value="neomluven" x-model="z.stav" /></td>
            <td><input class="input" type="text" x-model="z.poznamka" placeholder="" class="input-cell" /></td>
          </tr>
        </template>
        <tr x-show="zaznam.length===0"><td colspan="5" class="empty-state">V kategorii nejsou žádní hráči.</td></tr>
      </tbody>
    </table>
    <div class="form-actions">
      <a href="/dochazka" class="btn btn-secondary">Zrušit</a>
      <button class="btn btn-primary" :disabled="saving" @click="save()">
        <span x-show="!saving">Uložit docházku</span><span x-show="saving">Ukládám...</span>
      </button>
    </div>
  </div>
  <script is:inline define:vars={{ hraci }}>
    function newDochazka() {
      const tr=()=>{try{return JSON.parse(localStorage.getItem('trener_session')||'null');}catch{return null;}};
      return {
        f:{datum:new Date().toISOString().slice(0,10),typ:'trenink',popis:'',kategorie:'U13-U14'},
        zaznam:[],saving:false,success:false,error:'',
        init(){this.loadHraci();},
        loadHraci(){this.zaznam=hraci.filter(h=>h.kategorie===this.f.kategorie).map(h=>({hrac_id:h.id,jmeno:h.prijmeni+' '+h.jmeno,stav:'pritomen',poznamka:''}));},
        async save(){
          if(!this.f.datum){this.error='Vyplňte datum.';return;}
          this.saving=true;this.error='';
          const payload={...this.f,trener:tr()?.jmeno||'',zaznam:this.zaznam.map(z=>({hrac_id:z.hrac_id,stav:z.stav,poznamka:z.poznamka||undefined}))};
          try{const res=await fetch('/api/dochazka',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});if(!res.ok)throw new Error('Chyba');this.success=true;setTimeout(()=>window.location.href='/dochazka',1000);}
          catch(e){this.error=e.message;}finally{this.saving=false;}
        }
      };
    }
  </script>
</MainLayout>
